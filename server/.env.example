DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Refresh cookie: set Secure=false for local HTTP; true in production HTTPS
DJANGO_REFRESH_COOKIE_SECURE=False
DJANGO_COOKIE_SAMESITE=Lax

# --- Production admin bootstrap (consumed by `manage.py ensure_admin`) ---
# Set ALL THREE in your prod secret manager. The container start command runs
# ensure_admin on every boot; it creates the admin if missing and is a no-op
# otherwise (existing passwords are NEVER overwritten unless you run
# `manage.py ensure_admin --reset-password` manually).
# MAVUNO_ADMIN_EMAIL=ops@yourcompany.com
# MAVUNO_ADMIN_PASSWORD=use-a-strong-password-from-your-secret-manager
# MAVUNO_ADMIN_USERNAME=ops          # optional, defaults to email local-part
# MAVUNO_ADMIN_FIRST_NAME=Ops        # optional
# MAVUNO_ADMIN_LAST_NAME=Admin       # optional
